---
const {
	title = 'HabibX Design | Web Designer & Ecommerce Specialist',
	description = 'HabibX Design creates premium Shopify stores, landing pages, business websites, and Odoo / CRM digital systems for brands that want to look trusted and convert better.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta name="theme-color" content="#07111f" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		color-scheme: dark;
		--bg: #0b1020;
		--bg-deep: #050505;
		--bg-mid: #080a12;
		--surface: rgba(255, 255, 255, 0.075);
		--surface-strong: rgba(255, 255, 255, 0.12);
		--surface-dark: rgba(5, 5, 5, 0.72);
		--text: #ffffff;
		--text-soft: #dde3f0;
		--muted: #8a94a6;
		--soft: rgba(221, 227, 240, 0.58);
		--line: rgba(255, 255, 255, 0.14);
		--line-strong: rgba(255, 255, 255, 0.22);
		--blue: #4f8cff;
		--cyan: #35e2eb;
		--violet: #8b5cf6;
		--pink: #ec4899;
		--emerald: #34d399;
		--orange: #ff8a3d;
		--radius: 24px;
		--radius-sm: 14px;
		--holo: linear-gradient(135deg, var(--cyan), var(--violet) 52%, var(--pink));
		--shadow: 0 28px 90px rgba(0, 0, 0, 0.42);
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		background: var(--bg-deep);
		color: var(--text);
	}

	* {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		min-width: 320px;
		min-height: 100vh;
		background:
			radial-gradient(circle at 16% -8%, rgba(53, 226, 235, 0.24), transparent 31rem),
			radial-gradient(circle at 82% 0%, rgba(139, 92, 246, 0.26), transparent 34rem),
			radial-gradient(circle at 64% 18%, rgba(236, 72, 153, 0.14), transparent 28rem),
			linear-gradient(180deg, var(--bg-mid) 0%, var(--bg) 38%, var(--bg-deep) 100%);
		color: var(--text);
	}

	body::before {
		position: fixed;
		inset: 0;
		z-index: -1;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
		background-size: 72px 72px;
		mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.92), transparent 78%);
		content: "";
		pointer-events: none;
	}

	main {
		overflow: hidden;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	button,
	input,
	textarea {
		font: inherit;
	}

	img {
		max-width: 100%;
	}

	.section-shell {
		width: min(1160px, calc(100% - 40px));
		margin: 0 auto;
	}

	.section-pad {
		padding: 96px 0;
	}

	.kicker {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		margin: 0 0 14px;
		color: var(--cyan);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.kicker::before {
		width: 8px;
		height: 8px;
		border-radius: 999px;
		background: currentColor;
		box-shadow: 0 0 22px currentColor;
		content: "";
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1,
	h2,
	h3 {
		letter-spacing: -0.04em;
	}

	h1 {
		max-width: 760px;
		margin-bottom: 24px;
		font-size: clamp(3.15rem, 7.4vw, 6.9rem);
		line-height: 0.92;
	}

	h2 {
		margin-bottom: 16px;
		font-size: clamp(2.1rem, 4.4vw, 4.25rem);
		line-height: 0.98;
	}

	h3 {
		margin-bottom: 10px;
		font-size: 1.25rem;
		line-height: 1.12;
	}

	p {
		color: var(--muted);
		line-height: 1.7;
	}

	.section-heading {
		display: grid;
		grid-template-columns: minmax(0, 0.95fr) minmax(280px, 0.65fr);
		gap: 36px;
		align-items: end;
		margin-bottom: 34px;
	}

	.section-heading p {
		margin-bottom: 0;
	}

	.btn {
		display: inline-flex;
		min-height: 50px;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
		padding: 0 18px;
		font-weight: 800;
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			background 180ms ease,
			box-shadow 180ms ease;
	}

	.btn:hover {
		transform: translateY(-2px);
	}

	.btn-primary {
		background: var(--holo);
		color: white;
		box-shadow: 0 18px 42px rgba(139, 92, 246, 0.3);
	}

	.btn-secondary {
		border: 1px solid var(--line-strong);
		background: rgba(255, 255, 255, 0.06);
		color: var(--text);
	}

	.btn-secondary:hover {
		border-color: rgba(56, 232, 255, 0.48);
		background: rgba(56, 232, 255, 0.08);
	}

	.glass-card {
		border: 1px solid var(--line);
		background:
			linear-gradient(145deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.045)),
			rgba(255, 255, 255, 0.045);
		box-shadow: var(--shadow);
		backdrop-filter: blur(22px);
		-webkit-backdrop-filter: blur(22px);
	}

	@media (max-width: 860px) {
		.section-shell {
			width: min(100% - 28px, 680px);
		}

		.section-pad {
			padding: 72px 0;
		}

		.section-heading {
			grid-template-columns: 1fr;
			gap: 14px;
		}

		h1 {
			font-size: clamp(2.85rem, 13vw, 4.8rem);
		}
	}
</style>
