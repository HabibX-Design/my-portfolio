---
const projects = [
	{
		title: 'Shopify Supplement Store',
		description: 'Product page, bundle offers, subscription-ready layout',
		tag: 'Shopify ecommerce',
		className: 'supplement',
	},
	{
		title: 'Real Estate Landing Page',
		description: 'Lead-focused business page with property/service sections',
		tag: 'Lead generation',
		className: 'realestate',
	},
	{
		title: 'Odoo CRM Setup Page',
		description: 'Business system landing page for CRM, sales, inventory, and invoicing',
		tag: 'Digital systems',
		className: 'odoo',
	},
];
---

<section id="work" class="work section-pad">
	<div class="section-shell">
		<div class="section-heading">
			<div>
				<p class="kicker">Featured Work</p>
				<h2>Portfolio concepts built to sell the value fast.</h2>
			</div>
			<p>
				Each project direction is designed around trust, clarity, mobile responsiveness, and
				conversion-focused content structure.
			</p>
		</div>

		<div class="work-grid">
			{projects.map((project) => (
				<article class={`work-card glass-card ${project.className}`}>
					<div class="mockup" aria-hidden="true">
						<div class="mock-browser">
							<span></span>
							<span></span>
							<span></span>
						</div>
						<div class="mock-content">
							<div class="mock-hero"></div>
							<div class="mock-lines">
								<span></span>
								<span></span>
							</div>
							<div class="mock-grid">
								<span></span>
								<span></span>
								<span></span>
							</div>
						</div>
					</div>
					<div class="work-content">
						<p>{project.tag}</p>
						<h3>{project.title}</h3>
						<span>{project.description}</span>
					</div>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	.work {
		position: relative;
	}

	.work-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
	}

	.work-card {
		overflow: hidden;
		border-radius: var(--radius);
		transition:
			transform 220ms ease,
			border-color 220ms ease,
			box-shadow 220ms ease;
	}

	.work-card:hover {
		transform: translateY(-6px);
		border-color: rgba(56, 232, 255, 0.38);
		box-shadow: 0 30px 90px rgba(0, 0, 0, 0.46);
	}

	.mockup {
		position: relative;
		min-height: 310px;
		border-bottom: 1px solid var(--line);
		background: radial-gradient(circle at top right, rgba(56, 232, 255, 0.18), transparent 42%);
		padding: 20px;
	}

	.realestate .mockup {
		background: radial-gradient(circle at top right, rgba(52, 211, 153, 0.2), transparent 42%);
	}

	.odoo .mockup {
		background: radial-gradient(circle at top right, rgba(159, 122, 234, 0.22), transparent 42%);
	}

	.mock-browser {
		display: flex;
		gap: 7px;
		border: 1px solid var(--line);
		border-radius: 18px 18px 0 0;
		background: rgba(3, 7, 18, 0.62);
		padding: 12px;
	}

	.mock-browser span {
		width: 9px;
		height: 9px;
		border-radius: 999px;
		background: var(--cyan);
	}

	.mock-content {
		border: 1px solid var(--line);
		border-top: 0;
		border-radius: 0 0 18px 18px;
		background: rgba(3, 7, 18, 0.48);
		padding: 18px;
	}

	.mock-hero {
		height: 92px;
		margin-bottom: 18px;
		border-radius: 16px;
		background: linear-gradient(135deg, var(--blue), var(--cyan));
	}

	.realestate .mock-hero {
		background: linear-gradient(135deg, var(--emerald), var(--cyan));
	}

	.odoo .mock-hero {
		background: linear-gradient(135deg, var(--violet), var(--blue));
	}

	.mock-lines span {
		display: block;
		height: 11px;
		margin-bottom: 9px;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.14);
	}

	.mock-lines span:last-child {
		width: 68%;
	}

	.mock-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 10px;
		margin-top: 18px;
	}

	.mock-grid span {
		height: 58px;
		border: 1px solid var(--line);
		border-radius: 14px;
		background: rgba(255, 255, 255, 0.08);
	}

	.work-content {
		padding: 22px;
	}

	.work-content p {
		margin-bottom: 10px;
		color: var(--cyan);
		font-size: 0.78rem;
		font-weight: 800;
		text-transform: uppercase;
	}

	.realestate .work-content p {
		color: var(--emerald);
	}

	.odoo .work-content p {
		color: #c4b5fd;
	}

	.work-content h3 {
		margin-bottom: 12px;
		font-size: 1.45rem;
	}

	.work-content span {
		color: var(--muted);
		line-height: 1.6;
	}

	@media (max-width: 900px) {
		.work-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
