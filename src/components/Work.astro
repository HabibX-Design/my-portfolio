---
const projects = [
	{
		title: 'Shopify Supplement Store',
		description: 'Product page, subscription layout, bundles, and premium supplement branding.',
		tags: ['Shopify', 'Subscriptions', 'Bundles'],
		className: 'supplement',
	},
	{
		title: 'Real Estate Landing Page',
		description: 'Lead-generation page for property or service businesses.',
		tags: ['Landing Page', 'Leads', 'Business'],
		className: 'realestate',
	},
	{
		title: 'Odoo CRM Setup Page',
		description: 'Business system page for CRM, sales, inventory, and invoicing workflows.',
		tags: ['Odoo CRM', 'Systems', 'Automation'],
		className: 'odoo',
	},
];
---

<section id="work" class="work section-pad">
	<div class="section-shell">
		<div class="section-heading">
			<div>
				<p class="kicker">Featured Work</p>
				<h2>Projects built with a polished starter-theme feel.</h2>
			</div>
			<p>
				Each card uses a high-impact mockup preview so visitors understand the design quality
				before reading a single line of detail.
			</p>
		</div>

		<div class="work-grid">
			{projects.map((project) => (
				<article class={`work-card glass-card ${project.className}`}>
					<div class="case-preview" aria-hidden="true">
						<div class="case-glow"></div>
						<div class="case-window">
							<div class="window-nav">
								<span></span>
								<span></span>
								<span></span>
							</div>
							<div class="case-hero">
								<div class="case-copy">
									<i></i>
									<strong></strong>
									<small></small>
								</div>
								<div class="case-media"></div>
							</div>
							<div class="case-blocks">
								<span></span>
								<span></span>
								<span></span>
							</div>
						</div>
					</div>
					<div class="work-content">
						<div class="tag-row">
							{project.tags.map((tag) => <span>{tag}</span>)}
						</div>
						<h3>{project.title}</h3>
						<p>{project.description}</p>
					</div>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	.work {
		position: relative;
	}

	.work::before {
		position: absolute;
		inset: 10% auto auto 50%;
		width: 520px;
		height: 520px;
		border-radius: 50%;
		background: rgba(139, 92, 246, 0.12);
		content: "";
		filter: blur(80px);
		transform: translateX(-50%);
		pointer-events: none;
	}

	.work-grid {
		position: relative;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
	}

	.work-card {
		overflow: hidden;
		border-radius: var(--radius);
		transition:
			transform 240ms ease,
			border-color 240ms ease,
			box-shadow 240ms ease;
	}

	.work-card:hover {
		transform: translateY(-8px);
		border-color: rgba(53, 226, 235, 0.42);
		box-shadow: 0 34px 110px rgba(0, 0, 0, 0.52);
	}

	.case-preview {
		position: relative;
		min-height: 320px;
		overflow: hidden;
		border-bottom: 1px solid var(--line);
		background:
			radial-gradient(circle at 76% 20%, rgba(53, 226, 235, 0.2), transparent 34%),
			linear-gradient(145deg, rgba(79, 140, 255, 0.18), rgba(139, 92, 246, 0.1));
		padding: 24px;
	}

	.realestate .case-preview {
		background:
			radial-gradient(circle at 76% 20%, rgba(52, 211, 153, 0.2), transparent 34%),
			linear-gradient(145deg, rgba(52, 211, 153, 0.14), rgba(53, 226, 235, 0.1));
	}

	.odoo .case-preview {
		background:
			radial-gradient(circle at 76% 20%, rgba(236, 72, 153, 0.18), transparent 34%),
			linear-gradient(145deg, rgba(139, 92, 246, 0.18), rgba(236, 72, 153, 0.1));
	}

	.case-glow {
		position: absolute;
		right: -70px;
		top: -70px;
		width: 230px;
		height: 230px;
		border-radius: 50%;
		background: var(--holo);
		filter: blur(50px);
		opacity: 0.38;
	}

	.case-window {
		position: relative;
		z-index: 1;
		border: 1px solid rgba(255, 255, 255, 0.2);
		border-radius: 18px;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.13), rgba(255, 255, 255, 0.055)),
			rgba(5, 5, 5, 0.58);
		box-shadow: 0 26px 70px rgba(0, 0, 0, 0.34);
		transform: rotate(-1deg);
	}

	.work-card:hover .case-window {
		transform: rotate(0deg) translateY(-4px);
		transition: transform 240ms ease;
	}

	.window-nav {
		display: flex;
		gap: 7px;
		border-bottom: 1px solid var(--line);
		padding: 13px;
	}

	.window-nav span {
		width: 9px;
		height: 9px;
		border-radius: 999px;
		background: var(--cyan);
	}

	.window-nav span:nth-child(2) {
		background: var(--violet);
	}

	.window-nav span:nth-child(3) {
		background: var(--pink);
	}

	.case-hero {
		display: grid;
		grid-template-columns: 1fr 92px;
		gap: 14px;
		padding: 16px;
	}

	.case-copy,
	.case-media,
	.case-blocks span {
		border-radius: 16px;
		background: rgba(255, 255, 255, 0.1);
	}

	.case-copy {
		min-height: 130px;
		padding: 15px;
	}

	.case-copy i,
	.case-copy strong,
	.case-copy small {
		display: block;
		border-radius: 999px;
	}

	.case-copy i {
		width: 74px;
		height: 10px;
		margin-bottom: 30px;
		background: var(--holo);
	}

	.case-copy strong {
		width: 92%;
		height: 26px;
		margin-bottom: 10px;
		background: white;
	}

	.case-copy small {
		width: 62%;
		height: 10px;
		background: rgba(255, 255, 255, 0.18);
	}

	.case-media {
		background:
			radial-gradient(circle at 50% 34%, rgba(255, 255, 255, 0.78), transparent 31%),
			var(--holo);
	}

	.case-blocks {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 10px;
		padding: 0 16px 16px;
	}

	.case-blocks span {
		height: 58px;
	}

	.work-content {
		padding: 22px;
	}

	.tag-row {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin-bottom: 18px;
	}

	.tag-row span {
		border: 1px solid var(--line);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.055);
		padding: 7px 9px;
		color: var(--text-soft);
		font-size: 0.74rem;
		font-weight: 900;
	}

	.work-content h3 {
		margin-bottom: 12px;
		font-size: 1.5rem;
	}

	.work-content p {
		margin-bottom: 0;
	}

	@media (max-width: 960px) {
		.work-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
