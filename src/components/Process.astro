---
const steps = [
	['Discover', 'Understand your business, offer, audience, and what the website needs to achieve.'],
	['Design', 'Create a premium visual direction with clear structure, hierarchy, and conversion sections.'],
	['Build', 'Develop a responsive, fast-loading Astro website with clean frontend implementation.'],
	['Launch', 'Prepare the final site for Netlify deployment and help you improve from feedback.'],
];
---

<section id="process" class="process section-pad">
	<div class="section-shell">
		<div class="section-heading">
			<div>
				<p class="kicker">Process</p>
				<h2>A simple workflow from idea to polished launch.</h2>
			</div>
			<p>
				The process keeps the project focused, avoids messy revisions, and makes sure the final
				page feels business-ready.
			</p>
		</div>

		<div class="process-grid">
			{steps.map(([title, copy], index) => (
				<article class="process-step">
					<span>{String(index + 1).padStart(2, '0')}</span>
					<h3>{title}</h3>
					<p>{copy}</p>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	.process-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0;
		overflow: hidden;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: rgba(255, 255, 255, 0.045);
	}

	.process-step {
		position: relative;
		min-height: 260px;
		padding: 26px;
	}

	.process-step:not(:last-child) {
		border-right: 1px solid var(--line);
	}

	.process-step span {
		display: inline-flex;
		margin-bottom: 72px;
		color: var(--cyan);
		font-size: 0.82rem;
		font-weight: 900;
	}

	.process-step::after {
		position: absolute;
		top: 30px;
		right: 26px;
		width: 36px;
		height: 36px;
		border-radius: 999px;
		background:
			radial-gradient(circle, var(--cyan) 0 30%, transparent 31%),
			rgba(255, 255, 255, 0.08);
		content: "";
	}

	.process-step p {
		margin-bottom: 0;
	}

	@media (max-width: 900px) {
		.process-grid {
			grid-template-columns: 1fr 1fr;
		}

		.process-step:nth-child(2) {
			border-right: 0;
		}

		.process-step:nth-child(1),
		.process-step:nth-child(2) {
			border-bottom: 1px solid var(--line);
		}
	}

	@media (max-width: 560px) {
		.process-grid {
			grid-template-columns: 1fr;
		}

		.process-step {
			min-height: auto;
		}

		.process-step:not(:last-child) {
			border-right: 0;
			border-bottom: 1px solid var(--line);
		}

		.process-step span {
			margin-bottom: 42px;
		}
	}
</style>
