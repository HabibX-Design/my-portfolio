---
const steps = [
	['Discover', 'Understand your business, offer, audience, and what the website needs to achieve.'],
	['Design', 'Create a premium visual direction with clear structure, hierarchy, and conversion sections.'],
	['Build', 'Develop a responsive, fast-loading Astro website with clean frontend implementation.'],
	['Launch', 'Prepare the final site for Netlify deployment and help you improve from feedback.'],
];
---

<section id="process" class="process section-pad">
	<div class="section-shell">
		<div class="section-heading">
			<div>
				<p class="kicker">Process</p>
				<h2>From concept to launch.</h2>
			</div>
			<p>
				The process keeps the project focused, avoids messy revisions, and makes sure the final
				page feels business-ready.
			</p>
		</div>

		<div class="process-grid">
			{steps.map(([title, copy], index) => (
				<article class="process-step">
					<span>{String(index + 1).padStart(2, '0')}</span>
					<h3>{title}</h3>
					<p>{copy}</p>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	.process-grid {
		position: relative;
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 16px;
	}

	.process-grid::before {
		position: absolute;
		top: 44px;
		left: 9%;
		right: 9%;
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(53, 226, 235, 0.44), rgba(236, 72, 153, 0.44), transparent);
		content: "";
	}

	.process-step {
		position: relative;
		z-index: 1;
		min-height: 260px;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background:
			linear-gradient(145deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.045)),
			rgba(255, 255, 255, 0.04);
		box-shadow: 0 24px 70px rgba(0, 0, 0, 0.26);
		padding: 26px;
	}

	.process-step:not(:last-child) {
	}

	.process-step span {
		display: inline-flex;
		margin-bottom: 72px;
		border: 1px solid rgba(255, 255, 255, 0.16);
		border-radius: 999px;
		background: rgba(5, 5, 5, 0.62);
		padding: 9px 11px;
		color: var(--cyan);
		font-size: 0.82rem;
		font-weight: 900;
	}

	.process-step::after {
		position: absolute;
		top: 30px;
		right: 26px;
		width: 36px;
		height: 36px;
		border-radius: 999px;
		background:
			radial-gradient(circle, var(--cyan) 0 30%, transparent 31%),
			rgba(255, 255, 255, 0.08);
		content: "";
	}

	.process-step p {
		margin-bottom: 0;
	}

	@media (max-width: 900px) {
		.process-grid {
			grid-template-columns: 1fr 1fr;
		}

		.process-grid::before {
			display: none;
		}
	}

	@media (max-width: 560px) {
		.process-grid {
			grid-template-columns: 1fr;
		}

		.process-step {
			min-height: auto;
		}

		.process-step span {
			margin-bottom: 42px;
		}
	}
</style>
