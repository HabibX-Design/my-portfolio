---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main>
		<header class="topbar" aria-label="Primary navigation">
			<a class="brand" href="#home" aria-label="HabibX Design home">
				<span class="brand-mark">HXD</span>
				<span>HabibX Design</span>
			</a>
			<nav>
				<a href="#work">Work</a>
				<a href="#services">Services</a>
				<a href="#about">About</a>
				<a href="#contact">Contact</a>
			</nav>
		</header>

		<section id="home" class="hero">
			<div class="hero-copy">
				<p class="eyebrow">Portfolio website designer</p>
				<h1>I design premium websites with a dark modern feel.</h1>
				<p class="intro">
					Premium dark websites for personal brands, startups, and service businesses that
					need a sharp online presence.
				</p>
				<div class="actions">
					<a class="button primary" href="#work">View Work</a>
					<a class="button secondary" href="mailto:ecomwalahabib@gmail.com">Contact Me</a>
				</div>
			</div>

			<figure class="hero-media">
				<div class="portrait-frame">
					<img src="/hero-person.svg" alt="Premium portrait illustration for HabibX Design" />
					<div class="portrait-badge">
						<span>Available for</span>
						<strong>Web design projects</strong>
					</div>
				</div>
				<div class="portrait-stats" aria-label="Design highlights">
					<span>Responsive</span>
					<span>Fast</span>
					<span>Premium UI</span>
				</div>
			</figure>
		</section>

		<section class="proof-strip" aria-label="Capabilities">
			<span>Astro</span>
			<span>Responsive UI</span>
			<span>Landing Pages</span>
			<span>Portfolio Design</span>
		</section>

		<section id="work" class="section">
			<div class="section-heading">
				<p class="eyebrow">Selected work</p>
				<h2>Project directions</h2>
				<p>
					Use these as strong placeholders now. Later, replace them with real screenshots,
					results, and client details.
				</p>
			</div>

			<div class="work-grid">
				<article class="project large">
					<div class="project-visual visual-one">
						<div class="visual-window">
							<span class="visual-line wide"></span>
							<span class="visual-line"></span>
							<span class="visual-button"></span>
						</div>
					</div>
					<div class="project-content">
						<p>Portfolio</p>
						<h3>Personal brand website</h3>
					</div>
				</article>

				<article class="project">
					<div class="project-visual visual-two">
						<div class="phone-preview"></div>
					</div>
					<div class="project-content">
						<p>Business</p>
						<h3>Service landing page</h3>
					</div>
				</article>

				<article class="project">
					<div class="project-visual visual-three">
						<div class="dashboard-bars">
							<span></span>
							<span></span>
							<span></span>
						</div>
					</div>
					<div class="project-content">
						<p>Frontend</p>
						<h3>Responsive web interface</h3>
					</div>
				</article>
			</div>
		</section>

		<section id="services" class="services">
			<div class="section-heading compact">
				<p class="eyebrow">Services</p>
				<h2>What I build</h2>
			</div>
			<div class="service-list">
				<article>
					<span>01</span>
					<div>
						<h3>Portfolio Websites</h3>
						<p>Clean personal websites that present your work, skills, and contact details.</p>
					</div>
				</article>
				<article>
					<span>02</span>
					<div>
						<h3>Landing Pages</h3>
						<p>Focused pages for businesses, services, products, and online offers.</p>
					</div>
				</article>
				<article>
					<span>03</span>
					<div>
						<h3>Frontend Development</h3>
						<p>Fast Astro websites with responsive layouts and polished visual details.</p>
					</div>
				</article>
			</div>
		</section>

		<section id="about" class="about">
			<div class="about-mark">HX</div>
			<div>
				<p class="eyebrow">About</p>
				<h2>I am Habib, building a premium web design portfolio.</h2>
				<p>
					This site is my design home base. I am growing it with stronger projects, sharper
					visuals, and practical website builds for real online businesses.
				</p>
			</div>
		</section>

		<section id="contact" class="contact">
			<p class="eyebrow">Contact</p>
			<h2>Let us create a website that feels expensive, clear, and modern.</h2>
			<a class="button primary" href="mailto:ecomwalahabib@gmail.com">ecomwalahabib@gmail.com</a>
		</section>
	</main>
</Layout>

<style>
	a {
		color: inherit;
		text-decoration: none;
	}

	main {
		min-height: 100vh;
		overflow: hidden;
		background:
			linear-gradient(90deg, rgba(222, 184, 104, 0.06) 1px, transparent 1px),
			linear-gradient(rgba(222, 184, 104, 0.04) 1px, transparent 1px),
			#090909;
		background-size: 72px 72px;
		color: #f7f1e4;
	}

	.topbar {
		position: fixed;
		top: 22px;
		left: 50%;
		z-index: 10;
		display: flex;
		width: min(1040px, calc(100% - 32px));
		align-items: center;
		justify-content: space-between;
		gap: 18px;
		transform: translateX(-50%);
		border: 1px solid rgba(247, 241, 228, 0.16);
		border-radius: 999px;
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.04)),
			rgba(9, 9, 9, 0.48);
		box-shadow:
			0 24px 80px rgba(0, 0, 0, 0.42),
			inset 0 1px 0 rgba(255, 255, 255, 0.16);
		padding: 8px 9px 8px 10px;
		backdrop-filter: blur(22px) saturate(150%);
		-webkit-backdrop-filter: blur(22px) saturate(150%);
	}

	.brand,
	nav,
	.actions,
	.proof-strip,
	.project-content,
	.service-list article {
		display: flex;
		align-items: center;
	}

	.brand {
		gap: 12px;
		padding-right: 10px;
		font-weight: 800;
		letter-spacing: 0;
	}

	.brand-mark {
		display: grid;
		width: 40px;
		height: 40px;
		place-items: center;
		border: 1px solid rgba(222, 184, 104, 0.48);
		border-radius: 999px;
		background:
			linear-gradient(135deg, rgba(222, 184, 104, 0.92), rgba(247, 241, 228, 0.58)),
			#deb868;
		color: #0a0a0a;
		font-size: 12px;
		font-weight: 900;
		box-shadow: 0 0 30px rgba(222, 184, 104, 0.22);
	}

	nav {
		gap: 4px;
		border: 1px solid rgba(247, 241, 228, 0.08);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.05);
		padding: 4px;
	}

	nav a {
		border-radius: 999px;
		padding: 10px 14px;
		color: rgba(247, 241, 228, 0.74);
		font-size: 14px;
		font-weight: 800;
		transition:
			background 180ms ease,
			color 180ms ease,
			box-shadow 180ms ease;
	}

	nav a:hover {
		background: rgba(247, 241, 228, 0.1);
		color: #f7f1e4;
	}

	nav a:last-child {
		background: rgba(222, 184, 104, 0.95);
		color: #090909;
		box-shadow: 0 10px 28px rgba(222, 184, 104, 0.18);
	}

	nav a:last-child:hover {
		background: #f1cd78;
		color: #090909;
	}

	.hero,
	.section,
	.services,
	.about,
	.contact {
		width: min(1120px, calc(100% - 40px));
		margin: 0 auto;
	}

	.hero {
		display: grid;
		min-height: 100vh;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
		align-items: center;
		gap: 60px;
		padding: 132px 0 86px;
	}

	.hero-copy {
		max-width: 760px;
	}

	.eyebrow {
		margin: 0 0 16px;
		color: #deb868;
		font-size: 13px;
		font-weight: 800;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1 {
		margin-bottom: 24px;
		font-size: clamp(58px, 9vw, 132px);
		line-height: 0.9;
		letter-spacing: 0;
	}

	h2 {
		margin-bottom: 0;
		font-size: clamp(34px, 5vw, 68px);
		line-height: 0.98;
		letter-spacing: 0;
	}

	h3 {
		margin-bottom: 10px;
		font-size: 24px;
		line-height: 1.12;
		letter-spacing: 0;
	}

	.intro,
	.section-heading p,
	.service-list p,
	.about p {
		color: #bdb6aa;
		font-size: 19px;
		line-height: 1.65;
	}

	.intro {
		max-width: 620px;
		margin-bottom: 32px;
	}

	.actions {
		flex-wrap: wrap;
		gap: 12px;
	}

	.button {
		display: inline-flex;
		min-height: 50px;
		align-items: center;
		justify-content: center;
		border-radius: 8px;
		padding: 0 20px;
		font-weight: 800;
		transition:
			transform 180ms ease,
			background 180ms ease,
			border-color 180ms ease;
	}

	.button:hover {
		transform: translateY(-2px);
	}

	.primary {
		background: #deb868;
		color: #090909;
	}

	.secondary {
		border: 1px solid rgba(247, 241, 228, 0.24);
		color: #f7f1e4;
	}

	.secondary:hover {
		border-color: #deb868;
		background: rgba(222, 184, 104, 0.08);
	}

	.hero-media {
		position: relative;
		margin: 0;
	}

	.portrait-frame {
		position: relative;
		overflow: hidden;
		min-height: 640px;
		border: 1px solid rgba(222, 184, 104, 0.28);
		border-radius: 8px;
		background:
			radial-gradient(circle at 65% 20%, rgba(222, 184, 104, 0.18), transparent 34%),
			#101010;
		box-shadow: 0 36px 110px rgba(0, 0, 0, 0.52);
	}

	.portrait-frame::before {
		position: absolute;
		inset: 18px;
		border: 1px solid rgba(247, 241, 228, 0.1);
		border-radius: 8px;
		content: "";
		pointer-events: none;
	}

	.portrait-frame img {
		display: block;
		width: 100%;
		height: 640px;
		object-fit: cover;
		object-position: center;
	}

	.portrait-badge {
		position: absolute;
		right: 24px;
		bottom: 24px;
		width: min(270px, calc(100% - 48px));
		border: 1px solid rgba(247, 241, 228, 0.18);
		border-radius: 8px;
		background: rgba(9, 9, 9, 0.72);
		padding: 18px;
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
	}

	.portrait-badge span,
	.project-content p {
		margin-bottom: 12px;
		color: #deb868;
		font-size: 13px;
		font-weight: 800;
		text-transform: uppercase;
	}

	.portrait-badge strong {
		display: block;
		font-size: 24px;
		line-height: 1;
	}

	.portrait-stats {
		display: flex;
		position: absolute;
		left: 24px;
		top: 24px;
		flex-wrap: wrap;
		gap: 14px;
	}

	.portrait-stats span {
		border: 1px solid rgba(247, 241, 228, 0.12);
		border-radius: 999px;
		background: rgba(9, 9, 9, 0.58);
		padding: 10px 13px;
		color: #f7f1e4;
		font-size: 13px;
		font-weight: 800;
		backdrop-filter: blur(14px);
		-webkit-backdrop-filter: blur(14px);
	}

	.proof-strip {
		justify-content: center;
		gap: 12px;
		border-block: 1px solid rgba(222, 184, 104, 0.2);
		background: rgba(247, 241, 228, 0.035);
		padding: 18px;
		overflow-x: auto;
	}

	.proof-strip span {
		white-space: nowrap;
		border: 1px solid rgba(222, 184, 104, 0.22);
		border-radius: 999px;
		padding: 10px 14px;
		color: #d9d1c3;
		font-size: 14px;
		font-weight: 700;
	}

	.section,
	.services,
	.about {
		padding: 104px 0;
	}

	.section-heading {
		display: grid;
		grid-template-columns: 0.95fr 1.05fr;
		gap: 36px;
		align-items: end;
		margin-bottom: 34px;
	}

	.section-heading .eyebrow {
		grid-column: 1 / -1;
		margin-bottom: -18px;
	}

	.section-heading p {
		margin-bottom: 0;
	}

	.work-grid {
		display: grid;
		grid-template-columns: 1.1fr 0.9fr;
		gap: 18px;
	}

	.project {
		overflow: hidden;
		border: 1px solid rgba(222, 184, 104, 0.22);
		border-radius: 8px;
		background: #111111;
	}

	.project.large {
		grid-row: span 2;
	}

	.project-visual {
		position: relative;
		display: grid;
		min-height: 280px;
		place-items: center;
		border-bottom: 1px solid rgba(222, 184, 104, 0.16);
		background: #151515;
	}

	.large .project-visual {
		min-height: 560px;
	}

	.visual-one {
		background:
			linear-gradient(135deg, rgba(222, 184, 104, 0.18), transparent 48%),
			#151515;
	}

	.visual-two {
		background:
			linear-gradient(135deg, rgba(88, 166, 255, 0.13), transparent 45%),
			#121212;
	}

	.visual-three {
		background:
			linear-gradient(135deg, rgba(222, 184, 104, 0.12), transparent 48%),
			#191714;
	}

	.visual-window {
		width: min(78%, 460px);
		border: 1px solid rgba(222, 184, 104, 0.28);
		border-radius: 8px;
		background: rgba(9, 9, 9, 0.82);
		padding: 26px;
	}

	.visual-line,
	.visual-button {
		display: block;
		height: 14px;
		margin-bottom: 14px;
		border-radius: 999px;
		background: rgba(247, 241, 228, 0.18);
	}

	.visual-line.wide {
		width: 100%;
		height: 52px;
		background: #deb868;
	}

	.visual-line {
		width: 68%;
	}

	.visual-button {
		width: 120px;
		height: 38px;
		margin: 26px 0 0;
		background: #f7f1e4;
	}

	.phone-preview {
		width: 145px;
		height: 220px;
		border: 1px solid rgba(222, 184, 104, 0.36);
		border-radius: 22px;
		background:
			linear-gradient(#deb868 0 34%, transparent 34%),
			linear-gradient(90deg, transparent 0 16%, rgba(247, 241, 228, 0.15) 16% 84%, transparent 84%),
			#0b0b0b;
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
	}

	.dashboard-bars {
		display: grid;
		width: 70%;
		gap: 14px;
	}

	.dashboard-bars span {
		height: 54px;
		border: 1px solid rgba(222, 184, 104, 0.28);
		border-radius: 8px;
		background: rgba(247, 241, 228, 0.08);
	}

	.dashboard-bars span:nth-child(2) {
		width: 82%;
	}

	.dashboard-bars span:nth-child(3) {
		width: 62%;
	}

	.project-content {
		justify-content: space-between;
		gap: 18px;
		padding: 22px;
	}

	.project-content p {
		margin-bottom: 0;
	}

	.project-content h3 {
		max-width: 330px;
		margin-bottom: 0;
		text-align: right;
	}

	.services {
		display: grid;
		grid-template-columns: 0.75fr 1.25fr;
		gap: 48px;
		border-top: 1px solid rgba(222, 184, 104, 0.18);
		border-bottom: 1px solid rgba(222, 184, 104, 0.18);
	}

	.section-heading.compact {
		display: block;
		margin-bottom: 0;
	}

	.section-heading.compact .eyebrow {
		margin-bottom: 16px;
	}

	.service-list {
		display: grid;
		gap: 0;
	}

	.service-list article {
		gap: 28px;
		align-items: flex-start;
		border-top: 1px solid rgba(247, 241, 228, 0.12);
		padding: 24px 0;
	}

	.service-list article:last-child {
		border-bottom: 1px solid rgba(247, 241, 228, 0.12);
	}

	.service-list span {
		min-width: 44px;
		color: #deb868;
		font-weight: 900;
	}

	.service-list p {
		margin-bottom: 0;
	}

	.about {
		display: grid;
		grid-template-columns: 0.75fr 1.25fr;
		gap: 48px;
		align-items: center;
	}

	.about-mark {
		display: grid;
		min-height: 340px;
		place-items: center;
		border: 1px solid rgba(222, 184, 104, 0.24);
		border-radius: 8px;
		background:
			linear-gradient(135deg, rgba(222, 184, 104, 0.18), transparent 52%),
			#111111;
		color: #deb868;
		font-size: clamp(76px, 12vw, 140px);
		font-weight: 900;
	}

	.about h2 {
		margin-bottom: 22px;
	}

	.contact {
		display: grid;
		place-items: center;
		min-height: 520px;
		margin-bottom: 42px;
		border: 1px solid rgba(222, 184, 104, 0.24);
		border-radius: 8px;
		background:
			linear-gradient(135deg, rgba(222, 184, 104, 0.16), transparent 48%),
			#111111;
		padding: 56px;
		text-align: center;
	}

	.contact h2 {
		max-width: 840px;
		margin-bottom: 30px;
	}

	@media (max-width: 860px) {
		.topbar {
			top: 12px;
			width: min(100% - 20px, 680px);
			gap: 8px;
			padding: 7px;
		}

		.brand span:last-child {
			display: none;
		}

		nav {
			width: 100%;
			justify-content: flex-end;
			overflow-x: auto;
			padding: 3px;
		}

		nav a {
			padding: 9px 10px;
			font-size: 13px;
		}

		.hero,
		.section,
		.services,
		.about,
		.contact {
			width: min(100% - 28px, 680px);
		}

		.hero {
			grid-template-columns: 1fr;
			min-height: auto;
			gap: 42px;
			padding: 74px 0 58px;
		}

		h1 {
			font-size: clamp(54px, 17vw, 88px);
		}

		.portrait-frame {
			min-height: 480px;
		}

		.portrait-frame img {
			height: 480px;
		}

		.portrait-stats {
			left: 18px;
			top: 18px;
			gap: 8px;
		}

		.portrait-badge {
			right: 18px;
			bottom: 18px;
			width: calc(100% - 36px);
		}

		.proof-strip {
			justify-content: flex-start;
		}

		.section-heading,
		.work-grid,
		.services,
		.about {
			grid-template-columns: 1fr;
		}

		.section-heading .eyebrow {
			margin-bottom: -8px;
		}

		.project.large {
			grid-row: auto;
		}

		.large .project-visual,
		.project-visual {
			min-height: 340px;
		}

		.project-content {
			display: block;
		}

		.project-content p {
			margin-bottom: 8px;
		}

		.project-content h3 {
			text-align: left;
		}

		.services,
		.about {
			padding: 74px 0;
		}

		.service-list article {
			display: block;
		}

		.service-list span {
			display: block;
			margin-bottom: 10px;
		}

		.about-mark {
			min-height: 240px;
		}

		.contact {
			min-height: 420px;
			padding: 32px 18px;
		}

		.contact .button {
			width: 100%;
			padding-inline: 10px;
		}
	}
</style>
